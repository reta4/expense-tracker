# Backend API (required for production)
VITE_API_URL=http://localhost:3001/api

# Firebase web client config (from Firebase Console → Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: dev-only Vite proxy target (not used in production builds)
# VITE_SF_INSTANCE_URL=https://your-org.my.salesforce.com
