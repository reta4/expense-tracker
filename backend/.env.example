# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Salesforce Connected App (OAuth client_credentials)
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://your-org.my.salesforce.com/services/oauth2/token
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_API_VERSION=v60.0

# Firebase Admin SDK — choose ONE option:
# Option A (recommended for Render): paste the full JSON as a single line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B: path to a local key file (default: ./serviceAccountKey.json)
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
